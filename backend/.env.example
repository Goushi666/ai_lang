APP_NAME=ai_lang-backend
API_PREFIX=/api

# JWT
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256

# CORS
# For MVP allow all; production should restrict.
CORS_ALLOW_ORIGINS=*

# SQLite MVP
SQLITE_URL=sqlite+aiosqlite:///./app.db
# 传感器历史按天清理，0 表示不自动删
SENSOR_HISTORY_RETENTION_DAYS=0

# 环境分析
ANALYSIS_ENABLED=true
ANALYSIS_MAX_POINTS=5000
ANALYSIS_MIN_POINTS=3
ANALYSIS_STREAK_POINTS=3
ANALYSIS_MAX_ANOMALY_EXPORT_ROWS=10000
ANALYSIS_CHART_MAX_POINTS=1500
ANALYSIS_FORECAST_BASIS_POINTS=200
ANALYSIS_FORECAST_DAMPING_TAU_HOURS=10
ANALYSIS_FORECAST_MAX_SLOPE_C_PER_HOUR=1.5

# LSTM 温度预测（模型由 ml_training 训练后放到 backend/trained_models/）
FORECAST_USE_LSTM=true
FORECAST_LSTM_MODEL_PATH=trained_models/lstm_temp.pth
# 与 ml_training/config.WINDOW_SIZE 一致（默认 6）
FORECAST_LSTM_WINDOW_HOURS=6

# 百度智能云 IoT Core MQTT
MQTT_IOT_CORE_ID=ahxgrys
MQTT_REGION=gz
MQTT_DEVICE_KEY=ailang
MQTT_DEVICE_SECRET=xxx
MQTT_PORT=1883

# 建议：后端单独建「网关/应用」设备，填下面两项，避免与 MQTTX 现场设备互踢
MQTT_GATEWAY_KEY=
MQTT_GATEWAY_SECRET=

# MQTT ClientId：不要与 MQTTX 使用完全相同的默认 DeviceKey（见 MQTT_STRICT_DEVICE_CLIENT_ID）
MQTT_CLIENT_ID=ai-lang-backend
MQTT_UNIQUE_CLIENT_ID=true
MQTT_STRICT_DEVICE_CLIENT_ID=false

MQTT_ENABLED=true
# 传感器主题（模板里为 sensor/data）；多个主题用英文逗号分隔
MQTT_SUBSCRIBE_TOPICS=sensor/data
# 仅要真实 MQTT 数据、不要后端模拟传感器 tick 时设为 true（默认建议 true）
MQTT_DISABLE_SENSOR_SIM=true

# 智能 Agent：false 时 /api/agent/chat 返回 503
AGENT_ENABLED=true


# 复制为 backend/.env 后按环境修改；勿将含真实密钥的 .env 提交仓库。
# 配置项与 app/core/config.py 中 Settings 一一对应。

# ---------- 应用 ----------
APP_NAME=ai_lang-backend
API_PREFIX=/api

# ---------- JWT（生产环境务必改为随机长密钥）----------
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256

# ---------- CORS ----------
# 支持：*  或  http://localhost:5173,http://127.0.0.1:5173  或  JSON 数组 ["http://localhost:5173"]
# 通配 * 时后端会关闭 allow_credentials，避免 WebSocket 握手 403
CORS_ALLOW_ORIGINS=*

# ---------- 数据库 ----------
SQLITE_URL=sqlite+aiosqlite:///./app.db
# 传感器采样 + 已落库环境异常片段：仅保留最近 N 天，0=不删。Navicat 表格视图默认 LIMIT 1000 与库内总行数无关。
SENSOR_HISTORY_RETENTION_DAYS=7
# 仅影响 **读库**（把 naive 列按何墙钟理解）。MQTT 正常入库一律按 UTC naive，此处请保持留空。
# 若填写 Asia/Shanghai，会把库里数字当成「上海墙钟」再换算，而数据实为 UTC 时，会整体偏约 8 小时。
SQLITE_NAIVE_MEANS_TIMEZONE=
# MQTT JSON 无时区 ISO 按何墙钟解析；设备发 UTC 无时区串时改为 UTC
MQTT_NAIVE_ISO_TIMEZONE=Asia/Shanghai

# ---------- 百度智能云 IoT Core MQTT ----------
# 后端使用签名认证（见 app/core/mqtt.py），与百度控制台一致。
# SmartCar 手册主题示例：sensor/dht,sensor/light（或 sensor/#）
MQTT_IOT_CORE_ID=your-iot-core-id
MQTT_REGION=gz
MQTT_DEVICE_KEY=your-field-device-key
MQTT_DEVICE_SECRET=your-field-device-secret
MQTT_PORT=1883

MQTT_GATEWAY_KEY=your-web-backend-device-key
MQTT_GATEWAY_SECRET=your-web-backend-device-secret

MQTT_CLIENT_ID=web-server-or-custom
MQTT_UNIQUE_CLIENT_ID=true
MQTT_STRICT_DEVICE_CLIENT_ID=false

MQTT_ENABLED=true
MQTT_SUBSCRIBE_TOPICS=sensor/dht,sensor/light
MQTT_DISABLE_SENSOR_SIM=true
# Web → 树莓派：小车控制（手册 car/control，QoS 1）；留空则不发 MQTT
MQTT_TOPIC_CAR_CONTROL=car/control
MQTT_TOPIC_ARM_CONTROL=arm/control

# ---------- 环境分析 ----------
ANALYSIS_ENABLED=true
ANALYSIS_MAX_POINTS=5000
ANALYSIS_MIN_POINTS=3
ANALYSIS_STREAK_POINTS=3
ANALYSIS_MAX_ANOMALY_EXPORT_ROWS=10000
ANALYSIS_CHART_MAX_POINTS=1500
ANALYSIS_FORECAST_BASIS_POINTS=200
ANALYSIS_FORECAST_DAMPING_TAU_HOURS=10
ANALYSIS_FORECAST_MAX_SLOPE_C_PER_HOUR=1.5

# ---------- LSTM 温度预测 ----------
FORECAST_USE_LSTM=true
FORECAST_LSTM_MODEL_PATH=trained_models/lstm_temp.pth
FORECAST_LSTM_WINDOW_HOURS=6

# ---------- 智能 Agent ----------
AGENT_ENABLED=true

# ---------- 车载视频（见 doc/Web前端-MJPEG视频显示说明.md）----------
VIDEO_MJPEG_URL=http://192.168.137.114:8080/video_feed
VIDEO_HLS_PLAYLIST_URL=
VIDEO_PROXY_THROUGH_BACKEND=false
VIDEO_MJPEG_MEDIA_TYPE=multipart/x-mixed-replace; boundary=frame
